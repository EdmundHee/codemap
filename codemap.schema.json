{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Codemap Schema",
  "description": "Schema for codemap.json — a static analysis output mapping codebase relationships",
  "type": "object",
  "required": ["version", "generated_at", "project", "files"],
  "properties": {
    "version": { "type": "string", "description": "Schema version" },
    "generated_at": { "type": "string", "format": "date-time" },

    "project": {
      "type": "object",
      "required": ["name", "root", "languages", "frameworks"],
      "properties": {
        "name": { "type": "string" },
        "root": { "type": "string" },
        "languages": { "type": "array", "items": { "type": "string" } },
        "frameworks": { "type": "array", "items": { "type": "string" } },
        "entry_points": { "type": "array", "items": { "type": "string" } }
      }
    },

    "files": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["language", "hash", "exports", "imports"],
        "properties": {
          "language": { "type": "string" },
          "hash": { "type": "string" },
          "exports": { "type": "array", "items": { "type": "string" } },
          "imports": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["from", "symbols"],
              "properties": {
                "from": { "type": "string" },
                "symbols": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      }
    },

    "classes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["file", "methods"],
        "properties": {
          "file": { "type": "string" },
          "extends": { "type": ["string", "null"] },
          "implements": { "type": "array", "items": { "type": "string" } },
          "decorators": { "type": "array", "items": { "type": "string" } },
          "methods": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "params", "return_type"],
              "properties": {
                "name": { "type": "string" },
                "params": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["name", "type"],
                    "properties": {
                      "name": { "type": "string" },
                      "type": { "type": "string" },
                      "default": { "type": "string" },
                      "optional": { "type": "boolean" }
                    }
                  }
                },
                "return_type": { "type": "string" },
                "decorators": { "type": "array", "items": { "type": "string" } },
                "access": { "type": "string", "enum": ["public", "private", "protected"] },
                "async": { "type": "boolean" },
                "static": { "type": "boolean" },
                "calls": { "type": "array", "items": { "type": "string" } },
                "called_by": { "type": "array", "items": { "type": "string" } }
              }
            }
          },
          "properties": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "access": { "type": "string", "enum": ["public", "private", "protected"] }
              }
            }
          }
        }
      }
    },

    "functions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["file", "params", "return_type"],
        "properties": {
          "file": { "type": "string" },
          "params": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "default": { "type": "string" },
                "optional": { "type": "boolean" }
              }
            }
          },
          "return_type": { "type": "string" },
          "async": { "type": "boolean" },
          "exported": { "type": "boolean" },
          "calls": { "type": "array", "items": { "type": "string" } },
          "called_by": { "type": "array", "items": { "type": "string" } }
        }
      }
    },

    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["method", "path", "file", "handler"],
        "properties": {
          "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS", "HEAD"] },
          "path": { "type": "string" },
          "file": { "type": "string" },
          "handler": { "type": "string" },
          "middleware": { "type": "array", "items": { "type": "string" } },
          "params": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "source": { "type": "string", "enum": ["path", "query", "body", "header"] }
              }
            }
          }
        }
      }
    },

    "models": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["file", "fields"],
        "properties": {
          "file": { "type": "string" },
          "orm": { "type": "string" },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "primary": { "type": "boolean" },
                "unique": { "type": "boolean" },
                "nullable": { "type": "boolean" },
                "relation": { "type": "string" }
              }
            }
          },
          "relations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "target"],
              "properties": {
                "type": { "type": "string", "enum": ["hasOne", "hasMany", "belongsTo", "manyToMany"] },
                "target": { "type": "string" },
                "foreign_key": { "type": "string" },
                "through": { "type": "string" }
              }
            }
          }
        }
      }
    },

    "types": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["file", "kind"],
        "properties": {
          "file": { "type": "string" },
          "kind": { "type": "string", "enum": ["interface", "type", "enum", "class"] },
          "extends": { "type": "array", "items": { "type": "string" } },
          "properties": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "optional": { "type": "boolean" }
              }
            }
          },
          "used_by": { "type": "array", "items": { "type": "string" } }
        }
      }
    },

    "call_graph": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },

    "import_graph": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },

    "data_flows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "chain"],
        "properties": {
          "name": { "type": "string" },
          "chain": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["step", "function"],
              "properties": {
                "step": { "type": "integer" },
                "function": { "type": "string" },
                "input": { "type": "string" },
                "output": { "type": "string" }
              }
            }
          }
        }
      }
    },

    "config_dependencies": {
      "type": "object",
      "properties": {
        "env_vars": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "used_in": { "type": "array", "items": { "type": "string" } },
              "accessed_by": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "config_files": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "defines": { "type": "array", "items": { "type": "string" } },
              "referenced_by": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },

    "middleware": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["file"],
        "properties": {
          "file": { "type": "string" },
          "applied_to": { "type": "array", "items": { "type": "string" } },
          "calls": { "type": "array", "items": { "type": "string" } },
          "env_vars": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
